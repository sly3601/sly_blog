name = "sly-skill-tree-api"
main = "worker.js"
compatibility_date = "2026-05-25"
workers_dev = true
preview_urls = true

[[kv_namespaces]]
binding = "SKILL_TREE_KV"
id = "replace_with_your_kv_namespace_id"

[vars]
ALLOWED_ORIGINS = "https://sly3601.github.io,http://localhost:4002,http://localhost:4003"
# Optional Tencent Cloud COS image upload config for /write.
# Keep TENCENT_COS_SECRET_ID and TENCENT_COS_SECRET_KEY as Cloudflare secrets.
# TENCENT_COS_BUCKET = "sly-blog-1250000000"
# TENCENT_COS_REGION = "ap-guangzhou"
# TENCENT_COS_PUBLIC_BASE_URL = "https://img.example.com"
# TENCENT_COS_UPLOAD_PREFIX = "blog"
